{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "public": true,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/terraza",
      "destination": "/terraza/index.html"
    },
    {
      "source": "/terraza/",
      "destination": "/terraza/index.html"
    }
  ],
  "headers": [
    {
      "source": "/terraza/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}