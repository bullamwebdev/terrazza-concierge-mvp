{
  "version": 2,
  "builds": [
    {
      "src": "public/terraza/**",
      "use": "@vercel/static"
    },
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/terraza/assets/(.*)",
      "dest": "/public/terraza/assets/$1"
    },
    {
      "src": "/terraza/images/(.*)",
      "dest": "/public/terraza/images/$1"
    },
    {
      "src": "/terraza",
      "dest": "/public/terraza/index.html"
    },
    {
      "src": "/terraza/(.*)",
      "dest": "/public/terraza/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ]
}
