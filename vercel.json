{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "public": true,
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/terraza",
      "dest": "/terraza/index.html"
    },
    {
      "src": "/terraza/",
      "dest": "/terraza/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index"
    }
  ]
}