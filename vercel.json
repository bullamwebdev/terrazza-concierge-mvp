{
  "version": 2,
  "public": true,
  "builds": [
    {
      "src": "public/**",
      "use": "@vercel/static"
    },
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/terraza$",
      "dest": "/public/terraza/index.html"
    },
    {
      "src": "/terraza/(.*)",
      "dest": "/public/terraza/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ]
}