{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "public": true,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": "public/**"
      }
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/terraza",
      "dest": "/public/terraza/index.html"
    },
    {
      "src": "/terraza/",
      "dest": "/public/terraza/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ]
}