{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": "**/public/**"
      }
    }
  ],
  "routes": [
    {
      "src": "/terraza$",
      "dest": "/public/terraza/index.html"
    },
    {
      "src": "/terraza/assets/(.*)",
      "dest": "/public/terraza/assets/$1"
    },
    {
      "src": "/terraza/images/(.*)",
      "dest": "/public/terraza/images/$1"
    },
    {
      "src": "/terraza/(.*)",
      "dest": "/public/terraza/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ]
}