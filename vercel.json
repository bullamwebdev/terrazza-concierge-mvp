{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/terraza/assets/(.*)",
      "dest": "/public/terraza/assets/$1",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/terraza/images/(.*)",
      "dest": "/public/terraza/images/$1",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/terraza",
      "dest": "/public/terraza/index.html"
    },
    {
      "src": "/terraza/(.*)",
      "dest": "/public/terraza/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ]
}
