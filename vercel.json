{
  "version": 2,
  "public": true,
  "routes": [
    {
      "src": "/terraza$",
      "dest": "/public/terraza/index.html"
    },
    {
      "src": "/terraza/(.*)",
      "dest": "/public/terraza/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ]
}